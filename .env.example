# URL base da API do backend (obrigatório para o frontend funcionar).
# Desenvolvimento local (backend rodando em outro terminal):
#   VITE_API_URL=http://localhost:3000/api
# Produção (ex.: backend no Render) — use a mesma URL no Vercel:
#   VITE_API_URL=https://belier-system.onrender.com/api
VITE_API_URL=http://localhost:3000/api

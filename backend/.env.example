# Copie este arquivo para .env e preencha os valores.
# O .env não deve ser commitado no Git (adicione ao .gitignore).

# Porta em que a API vai rodar
PORT=3001

# Chave secreta para assinar os JWTs (troque por uma string aleatória longa em produção)
JWT_SECRET=sua-chave-secreta-muito-segura-aqui

# Desenvolvimento: banco SQLite (arquivo)
DATABASE_PATH=./database.sqlite

# Produção/hospedagem: URL do PostgreSQL (ex.: Render, Railway)
# DATABASE_URL=postgres://usuario:senha@host:5432/nome_do_banco
